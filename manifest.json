{
  "manifest_version": 3,
  "name": "Notion Palette Pro",
  "version": "1.0",
  "description": "Premium curated color themes for your Notion workspace.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["*://*.notion.so/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Customize Notion Theme"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.notion.so/*"],
      "js": ["content.js"],
      "css": ["theme.css"],
      "run_at": "document_start"
    }
  ]
}
